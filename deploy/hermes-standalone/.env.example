# Copy to .env in this same directory and fill in. These two are SHARED
# SECRETS — generate them once here, then set the identical values as Fly
# secrets on the main emergent-interaction-lab app (see this directory's
# README.md for the exact `fly secrets set` commands). If they don't match
# byte-for-byte on both sides, every Hermes turn fails its auth handshake.

# Same key the Fly backend already uses (fly secrets list should show it) —
# Hermes's nvidia provider reads this exact variable, so one key powers both.
NVIDIA_API_KEY=

# Generate with: openssl rand -hex 32
# This is what the Fly backend presents to authenticate INTO this Hermes
# gateway. Unlike the bundled deployment (which regenerates this per boot
# because both processes share one container's lifetime), this one is a
# durable secret across two independently-restarting hosts, so it must be
# generated once and stored on both sides.
HERMES_API_KEY=

# Generate with: openssl rand -hex 32
# The reverse direction: what Hermes presents when it calls back into the
# lab's own MCP server to write a research note. Must match the
# EIL_MCP_TOKEN Fly secret exactly.
EIL_MCP_TOKEN=

# The lab's MCP endpoint — the real, public Fly URL (Hermes now runs on a
# different host entirely, so "loopback" no longer applies).
EIL_MCP_URL=https://emergent-interaction-lab.fly.dev/api/mcp

# The public domain this Hermes instance answers on, e.g. hermes.rfi-irfos.com
# — needs a DNS A/AAAA record pointed at this server's IP before `docker
# compose up`, so Caddy's Let's Encrypt handshake can succeed.
HERMES_DOMAIN=

# Optional — overrides deploy/hermes-config.yaml's default model.
HERMES_MODEL=
