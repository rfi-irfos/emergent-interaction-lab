# ── Development ──────────────────────────────────────────────────────────────
# Set to true to bypass Google auth (auto-login as "Developer")
DEV_MODE=true

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URI=http://localhost:3000/auth/callback

# Only this Gmail address can log in as admin
ALLOWED_EMAIL=your@gmail.com

# ── Paths (optional) ──────────────────────────────────────────────────────────
# Where to store the site content JSON
CONTENT_PATH=content.json
# Where to store uploaded images
UPLOADS_DIR=uploads
# Where the built React frontend lives (after: cd frontend && npm run build)
STATIC_DIR=../frontend/dist

# ── Hermes research engine (optional) ─────────────────────────────────────────
# Lets the Forschung tab run on a Hermes agent instead of the built-in Jarvis
# loop — see "Hermes research engine" in the README.
#
# IN THE DEPLOYED IMAGE you don't set anything here: Hermes is bundled, and it
# uses the same NVIDIA_API_KEY the backend already has. start.sh generates the
# internal handshake key and wires both sides up. Optional overrides there:
#   HERMES_ENABLED=0        don't start the bundled agent at all
#   HERMES_MODEL=<model>    override the default model
#
# The two vars below are for LOCAL DEV, when you want to point at a Hermes you
# are running yourself. Leave them empty and nothing changes: the engine picker
# never appears and every research turn takes the built-in path.
#
# Server-side only: the browser is never told where Hermes lives, and never sees
# the key below.
HERMES_URL=
# Must match the API_SERVER_KEY that Hermes's API server was started with.
HERMES_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
